# security-recipes MCP server configuration

# URL to the generated index.json from your Hugo site (GitHub Pages or custom host).
source_index_url = "https://security-recipes.ai/recipes-index.json"

# Security allow-list: hostname from source_index_url MUST exist here.
allowed_source_hosts = ["security-recipes.ai"]

# Public URL where this MCP server itself is hosted (metadata only).
# Change this to your own hostname/subdomain when self-hosting.
server_public_base_url = "https://mcp.security-recipes.ai"

# Local workflow-control-plane manifest exposed through the
# recipes_workflow_control_plane MCP tool.
control_plane_manifest_path = "./data/control-plane/workflow-manifests.json"

# Generated policy pack exposed through the recipes_mcp_gateway_policy and
# recipes_evaluate_mcp_gateway_decision MCP tools.
gateway_policy_path = "./data/policy/mcp-gateway-policy.json"

# Generated assurance pack exposed through the recipes_agentic_assurance_pack MCP tool.
assurance_pack_path = "./data/evidence/agentic-assurance-pack.json"

# Generated non-human identity and delegation ledger exposed through the
