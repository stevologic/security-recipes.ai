# security-recipes MCP server configuration

# URL to the generated index.json from your Hugo site (GitHub Pages or custom host).
source_index_url = "https://security-recipes.ai/recipes-index.json"

# Security allow-list: hostname from source_index_url MUST exist here.
allowed_source_hosts = ["security-recipes.ai"]

# Public URL where this MCP server itself is hosted (metadata only).
# Change this to your own hostname/subdomain when self-hosting.
server_public_base_url = "https://mcp.security-recipes.ai"

# Local workflow-control-plane manifest exposed through the
# recipes_workflow_control_plane MCP tool.
control_plane_manifest_path = "./data/control-plane/workflow-manifests.json"

# Generated policy pack exposed through the recipes_mcp_gateway_policy and
# recipes_evaluate_mcp_gateway_decision MCP tools.
gateway_policy_path = "./data/policy/mcp-gateway-policy.json"

# Generated assurance pack exposed through the recipes_agentic_assurance_pack MCP tool.
assurance_pack_path = "./data/evidence/agentic-assurance-pack.json"

# Generated non-human identity and delegation ledger exposed through the
# recipes_agent_identity_ledger MCP tool.
identity_ledger_path = "./data/evidence/agent-identity-delegation-ledger.json"

# Generated MCP connector trust pack exposed through the
# recipes_mcp_connector_trust_pack MCP tool.
connector_trust_pack_path = "./data/evidence/mcp-connector-trust-pack.json"

# Generated MCP connector intake pack exposed through the
# recipes_mcp_connector_intake_pack MCP tool.
connector_intake_pack_path = "./data/evidence/mcp-connector-intake-pack.json"

# Generated MCP authorization conformance pack exposed through the
# recipes_mcp_authorization_conformance_pack and
# recipes_evaluate_mcp_authorization_decision MCP tools.
authorization_conformance_pack_path = "./data/evidence/mcp-authorization-conformance-pack.json"

# Generated agentic red-team drill pack exposed through the
# recipes_agentic_red_team_drill_pack MCP tool.
red_team_drill_pack_path = "./data/evidence/agentic-red-team-drill-pack.json"

# Generated agentic readiness scorecard exposed through the
# recipes_agentic_readiness_scorecard MCP tool.
readiness_scorecard_path = "./data/evidence/agentic-readiness-scorecard.json"

# Generated agent capability risk register exposed through the
# recipes_agent_capability_risk_register MCP tool.
capability_risk_register_path = "./data/evidence/agent-capability-risk-register.json"

# Generated agent memory boundary pack exposed through the
# recipes_agent_memory_boundary_pack and
# recipes_evaluate_agent_memory_decision MCP tools.
agent_memory_boundary_pack_path = "./data/evidence/agent-memory-boundary-pack.json"

# Generated agent skill supply-chain pack exposed through the
# recipes_agent_skill_supply_chain_pack and
# recipes_evaluate_agent_skill_decision MCP tools.
agent_skill_supply_chain_pack_path = "./data/evidence/agent-skill-supply-chain-pack.json"

# Generated Agentic System Bill of Materials exposed through the
# recipes_agentic_system_bom MCP tool.
agentic_system_bom_path = "./data/evidence/agentic-system-bom.json"

# Generated agentic run receipt pack exposed through the
# recipes_agentic_run_receipt_pack MCP tool.
agentic_run_receipt_pack_path = "./data/evidence/agentic-run-receipt-pack.json"

# Generated secure context provenance and retrieval trust pack exposed through
# the recipes_secure_context_trust_pack and
# recipes_evaluate_context_retrieval_decision MCP tools.
secure_context_trust_pack_path = "./data/evidence/secure-context-trust-pack.json"

# Generated secure context attestation pack exposed through the
# recipes_secure_context_attestation_pack and
# recipes_evaluate_context_attestation_decision MCP tools.
secure_context_attestation_pack_path = "./data/evidence/secure-context-attestation-pack.json"

# Generated secure context eval pack exposed through the
# recipes_secure_context_eval_pack and
# recipes_evaluate_secure_context_eval_case MCP tools.
secure_context_eval_pack_path = "./data/evidence/secure-context-eval-pack.json"

# Generated context poisoning guard pack exposed through the
# recipes_context_poisoning_guard_pack MCP tool.
context_poisoning_guard_pack_path = "./data/evidence/context-poisoning-guard-pack.json"

# Generated context egress boundary pack exposed through the
# recipes_context_egress_boundary_pack and
# recipes_evaluate_context_egress_decision MCP tools.
context_egress_boundary_pack_path = "./data/evidence/context-egress-boundary-pack.json"

# Generated source-backed agentic threat and product radar exposed through
# the recipes_agentic_threat_radar MCP tool.
threat_radar_path = "./data/evidence/agentic-threat-radar.json"

# Generated agentic control plane blueprint exposed through the
# recipes_agentic_control_plane_blueprint MCP tool.
control_plane_blueprint_path = "./data/evidence/agentic-control-plane-blueprint.json"

# Generated agentic measurement probe pack exposed through the
# recipes_agentic_measurement_probe_pack MCP tool.
measurement_probe_pack_path = "./data/evidence/agentic-measurement-probe-pack.json"

# Cache and behavior tuning
cache_ttl_seconds = 3600
request_timeout_seconds = 15
max_results_default = 8
max_results_cap = 25
