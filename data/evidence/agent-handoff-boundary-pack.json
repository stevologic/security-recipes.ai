  "decision_contract": {
    "decisions": [
      {
        "decision": "allow_metadata_handoff",
        "meaning": "Only task metadata, workflow IDs, source IDs, source hashes, and approval-required flags cross the boundary."
      },
      {
        "decision": "allow_cited_evidence_handoff",
        "meaning": "Redacted, cited evidence may cross the boundary with source IDs, hashes, and egress decision evidence."
      },
      {
        "decision": "allow_approved_handoff",
        "meaning": "A higher-risk handoff may proceed because explicit approval, trace correlation, and delegated authority evidence are present."
      },
      {
        "decision": "hold_for_redaction_or_approval",
        "meaning": "The handoff is potentially valid but requires redaction, DPA or residency checks, signed agent identity, or human approval."
      },
      {
        "decision": "deny_untrusted_agent_handoff",
        "meaning": "The target agent, protocol, authentication, or trust tier is not approved for the requested payload or capability."
      },
      {
        "decision": "deny_unregistered_handoff",
        "meaning": "The workflow, protocol, or handoff profile is not registered."
      },
      {
        "decision": "kill_session_on_secret_handoff",
        "meaning": "The handoff attempted to move credential material, raw tokens, private keys, signing material, internal memory, or hidden instructions."
      }
    ],
    "default_state": "deny_unregistered_handoff",
    "global_rules": [
      "Agent-to-agent payloads must be treated as egress events, not chat messages.",
      "A remote agent is opaque; do not assume its memory, tools, model, or downstream connectors are visible to SecurityRecipes.",
      "Handoffs may carry cited conclusions, source IDs, source hashes, workflow IDs, approval state, and correlation IDs by default.",
      "Handoffs must not carry internal memory, raw tool traces, hidden prompts, unrestricted customer logs, credentials, or live signing material.",
      "High-impact capabilities require explicit human approval and a scoped identity or delegated authority record before handoff."
    ],
