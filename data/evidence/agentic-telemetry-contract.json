  },
  "enterprise_adoption_packet": {
    "board_level_claim": "SecurityRecipes can make agentic telemetry useful for audit and detection without turning observability into a prompt, tool-argument, or secret exfiltration sink.",
    "default_questions_answered": [
      "Which trace fields must exist before an agent run is trusted?",
      "Which OpenTelemetry and MCP attributes should an enterprise collector require?",
      "Which prompt, output, tool argument, and tool result fields are opt-in only?",
      "Which telemetry findings force hold, deny, or kill-session decisions?",
      "Which runtime fields connect traces to run receipts, context packs, egress decisions, and incidents?"
    ],
    "recommended_first_use": "Attach the generated telemetry contract to AI platform logging standards, MCP gateway requirements, SIEM onboarding, procurement security reviews, and acquisition diligence.",
    "sales_motion": "Lead with open trace contracts, then sell hosted collector policy, redaction verification, trace-to-receipt retention, SIEM export, and agentic incident evidence vaulting."
  },
