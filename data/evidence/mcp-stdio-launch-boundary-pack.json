    "decisions": [
      {
        "decision": "allow_pinned_sandboxed_stdio_launch",
        "meaning": "The launch matches a registered command, package, sandbox, environment, network, filesystem, and evidence boundary."
      },
      {
        "decision": "hold_for_owner_review",
        "meaning": "The launch is registered but is missing evidence, sandboxing, approval, or narrowed environment and network controls."
      },
      {
        "decision": "deny_unregistered_stdio_launch",
        "meaning": "The launch ID or profile is unknown and cannot start without intake."
      },
      {
        "decision": "deny_untrusted_package_launch",
        "meaning": "The launch depends on package-runner bootstrap, floating versions, unverified publishers, or missing digest/signature evidence."
      },
      {
        "decision": "deny_shell_or_network_bootstrap",
        "meaning": "The launch uses shell wrappers, dangerous argument chaining, broad network bootstrap, private-network reachability, or command drift."
      },
      {
        "decision": "kill_session_on_secret_or_privilege_request",
        "meaning": "The launch attempts to expose secrets, inherited credentials, privileged execution, or prohibited host access."
      }
    ],
