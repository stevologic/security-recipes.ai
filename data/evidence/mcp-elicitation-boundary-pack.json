      "id": "server_identity_display",
      "severity": "high"
    },
    {
      "applies_to": "all_elicitation",
      "control_reason": "Elicitation is safe only when users can decline or cancel without the agent silently treating non-response as consent.",
      "evidence_key": "user_can_decline",
      "id": "decline_and_cancel_available",
      "severity": "medium"
    },
    {
      "applies_to": "form_mode",
      "control_reason": "Form-mode submissions should be reviewable and editable before user-provided data returns to the MCP server.",
      "evidence_key": "user_can_review",
      "id": "form_response_review",
      "severity": "medium"
    },
    {
      "applies_to": "form_mode",
      "control_reason": "Passwords, API keys, tokens, private keys, payment credentials, and session cookies must not be requested through form mode.",
      "evidence_key": "response_schema_fields",
      "id": "form_sensitive_field_blocklist",
      "severity": "critical"
    },
    {
      "applies_to": "sensitive_interaction",
      "control_reason": "Sensitive interactions belong in URL mode so credentials and payments never pass through the LLM context or MCP client.",
      "evidence_key": "mode",
      "id": "url_mode_for_sensitive_flows",
      "severity": "critical"
    },
    {
      "applies_to": "url_mode",
      "control_reason": "Non-development URL-mode interactions should use HTTPS so user inputs are not exposed in transit.",
      "evidence_key": "https_url",
      "id": "https_url_requirement",
      "severity": "high"
    },
    {
      "applies_to": "url_mode",
      "control_reason": "URL-mode requests need domain review to reduce phishing, subdomain spoofing, and malicious redirect risk.",
      "evidence_key": "url_allowlisted",
      "id": "domain_allowlist",
      "severity": "high"
    },
    {
      "applies_to": "url_mode",
      "control_reason": "Pre-authenticated URLs can impersonate users if exposed to a malicious client or logged in the wrong place.",
      "evidence_key": "preauthenticated_url",
      "id": "no_preauthenticated_url",
      "severity": "critical"
    },
    {
      "applies_to": "url_mode",
      "control_reason": "URLs sent through MCP must not embed credentials, tokens, PII, payment data, or other sensitive values.",
      "evidence_key": "url_contains_sensitive_data",
      "id": "no_sensitive_data_in_url",
      "severity": "critical"
    },
    {
      "applies_to": "url_mode",
      "control_reason": "Clients must not open URL-mode interactions without explicit consent after presenting the target URL.",
      "evidence_key": "user_consent_recorded",
      "id": "explicit_user_consent",
      "severity": "high"
    },
    {
      "applies_to": "url_mode",
      "control_reason": "URL previews and metadata fetches can leak tokens, identifiers, or intent to an untrusted destination.",
      "evidence_key": "url_prefetched",
      "id": "no_url_prefetch",
      "severity": "medium"
    },
    {
      "applies_to": "third_party_authorization",
      "control_reason": "Third-party credentials obtained through URL mode must never transit the MCP client or be forwarded as token passthrough.",
      "evidence_key": "token_or_secret_transit",
      "id": "external_token_boundary",
      "severity": "critical"
    },
    {
      "applies_to": "third_party_authorization",
      "control_reason": "External OAuth via URL mode is separate from MCP authorization and must not be treated as permission for the MCP client itself.",
      "evidence_key": "authorization_pack_hash",
      "id": "mcp_authorization_separation",
      "severity": "critical"
    },
    {
      "applies_to": "stateful_elicitation",
      "control_reason": "Elicitation state should be bound to the user identity, not only an MCP session identifier.",
      "evidence_key": "user_id",
      "id": "user_identity_binding",
      "severity": "high"
    },
    {
      "applies_to": "all_elicitation",
      "control_reason": "Each prompt needs a stable ID so completion notifications, retries, receipts, and incident review bind to the original request.",
      "evidence_key": "elicitation_id",
      "id": "elicitation_id_correlation",
      "severity": "medium"
    },
    {
      "applies_to": "url_mode",
      "control_reason": "URL completion notifications must only satisfy the original client and elicitation ID.",
      "evidence_key": "completion_notification_bound",
      "id": "completion_notification_binding",
      "severity": "medium"
    },
    {
      "applies_to": "all_elicitation",
      "control_reason": "Repeated prompts can become social engineering pressure, especially when an agent sees untrusted content.",
      "evidence_key": "prompt_rate_limited",
      "id": "rate_limit_repeated_prompts",
      "severity": "medium"
    },
    {
      "applies_to": "all_elicitation",
      "control_reason": "Elicitation requests need receipt evidence for buyer review, incident response, and user trust investigations.",
      "evidence_key": "correlation_id",
      "id": "run_receipt_logging",
      "severity": "high"
    }
  ],
