  "buyer_due_diligence_questions": [
    {
      "answer_contract": "Return form-mode deny rules, sensitive data classes, profile decisions, source references, and runtime evaluator outcomes.",
      "id": "elicitation-sensitive-data",
      "question": "Can MCP servers request secrets, payment data, or tokens through ordinary form prompts?"
    },
    {
      "answer_contract": "Return URL-mode safe handling rules, allowlisted domains, no-prefetch controls, consent requirements, and deny decisions for untrusted URLs.",
      "id": "elicitation-url-safety",
      "question": "What prevents an MCP server or prompt-injection-controlled tool result from sending users to a malicious URL?"
    },
    {
      "answer_contract": "Return the authorization separation controls, source references, required hashes, and token-passthrough deny behavior.",
      "id": "elicitation-auth-separation",
      "question": "How does external OAuth through URL mode differ from MCP authorization?"
    },
    {
      "answer_contract": "Return required receipt fields, workflow mappings, generated pack hashes, and the correlation fields needed for enterprise review.",
      "id": "elicitation-receipts",
      "question": "Can a buyer review who asked the user for information, why, and what decision was made?"
    }
  ],
  "commercialization_path": {
    "acquirer_value": "A strategic acquirer gets a production MCP safety primitive for the point where agents ask humans for data or route them to external authorization flows.",
    "enterprise_layer": "Sell hosted domain allowlists, consent receipt storage, connector setup flows, phishing telemetry, policy APIs, and customer-specific elicitation replay.",
    "open_layer": "Publish form-mode and URL-mode elicitation rules as open evidence so MCP clients can adopt a clear safe-by-default pattern."
  },
  "control_checks": [
    {
      "applies_to": "all_elicitation",
      "control_reason": "Servers must not send elicitation requests for modes the client did not declare.",
      "evidence_key": "client_capabilities",
      "id": "client_capability_check",
      "severity": "high"
    },
    {
      "applies_to": "all_elicitation",
      "control_reason": "The user must know which MCP server is requesting information before accepting, declining, or canceling.",
