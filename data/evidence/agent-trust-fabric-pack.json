  "runtime_policy": {
    "decision_order": [
      "kill_session_on_agent_trust_break",
      "deny_untrusted_agent",
      "hold_for_trust_evidence",
      "hold_for_step_up",
      "allow_trusted_agent_context"
    ],
    "deny_when": [
      "workflow is unknown",
      "requested trust tier exceeds generated workflow tier and no approval exists",
      "required evidence fields are missing after normalization",
      "trust score falls below deny threshold"
