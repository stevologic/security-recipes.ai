  "action_contract": {
    "decision_ladder": [
      {
        "decision": "allow_bounded_action",
        "meaning": "The action is registered for the workflow, low or bounded impact, policy-bound, receipt-backed, and has no runtime kill signal."
      },
      {
        "decision": "hold_for_action_evidence",
        "meaning": "The action shape is plausible but missing context, policy, identity, receipt, authorization, egress, telemetry, or risk evidence needed for a production decision."
      },
      {
        "decision": "hold_for_human_approval",
        "meaning": "The action can proceed only after a linked human approval or risk acceptance is attached to the run evidence."
      },
      {
        "decision": "deny_unregistered_action",
        "meaning": "The workflow has not registered this action class or requested capability."
      },
      {
        "decision": "deny_unapproved_high_impact_action",
        "meaning": "The action is high impact and lacks required approval, risk acceptance, or policy-bound evidence."
      },
      {
        "decision": "kill_session_on_runtime_action_signal",
        "meaning": "A kill signal indicates secret exposure, token passthrough, revoked identity use, cross-tenant movement, repeated denied calls, or irreversible side effects."
      }
    ],
    "default_state": "action_untrusted_until_context_policy_intent_behavior_identity_and_receipt_evidence_are_bound",
