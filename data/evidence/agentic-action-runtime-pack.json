    {
      "coverage": "Maps runtime action controls to tool misuse, goal hijacking, identity abuse, insecure inter-agent communication, memory poisoning, unexpected code execution, and rogue-agent containment.",
      "id": "owasp-agentic-top-10-2026",
      "name": "OWASP Top 10 for Agentic Applications 2026",
      "url": "https://genai.owasp.org/resource/owasp-top-10-for-agentic-applications-for-2026/"
    },
    {
      "coverage": "Applies confused-deputy prevention, command review, sandboxing, least privilege, scope minimization, and local-server privilege boundaries to action-level decisions.",
      "id": "mcp-security-best-practices-2025",
      "name": "Model Context Protocol Security Best Practices",
      "url": "https://modelcontextprotocol.io/docs/tutorials/security/security_best_practices"
    },
    {
      "coverage": "Requires OAuth 2.1, protected resource metadata, resource indicators, audience validation, PKCE, exact redirect handling, short-lived tokens, and forbidden token passthrough before protected MCP actions proceed.",
      "id": "mcp-authorization-2025-11-25",
      "name": "Model Context Protocol Authorization Specification",
      "url": "https://modelcontextprotocol.io/specification/2025-11-25/basic/authorization"
    },
    {
      "coverage": "Connects runtime action evidence to generative AI governance, measurement, monitoring, incident response, third-party component risk, and risk treatment across the AI lifecycle.",
      "id": "nist-ai-600-1",
      "name": "NIST AI RMF Generative AI Profile",
      "url": "https://www.nist.gov/publications/artificial-intelligence-risk-management-framework-generative-artificial-intelligence"
