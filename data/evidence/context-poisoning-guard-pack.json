  "intent": "Add a deterministic context-poisoning guard for the SecurityRecipes secure context layer: every registered source root is scanned for prompt-injection, tool-result-injection, approval-bypass, hidden-instruction, encoded-payload, and secret-exfiltration markers before it is treated as MCP-retrievable context.",
  "positioning": {
    "buyer": "AI Platform, Security Engineering, AppSec, Product Security, red teams, GRC, procurement security, and acquisition diligence teams",
    "category": "Secure-context poisoning detection for agentic AI and MCP",
    "enterprise_promise": "SecurityRecipes can prove not only which context is registered and hashed, but also whether the current context corpus contains instruction-like payloads that should be demoted, reviewed, or blocked before agents consume it.",
    "why_now": "Prompt injection, tool poisoning, and MCP connector sprawl turn context into an attack surface. Enterprise buyers need deterministic pre-retrieval inspection in addition to model behavior guidance."
  },
  "prevention_controls": [
    "Demote retrieved text to evidence before model use.",
    "Label documented attack payloads as adversarial examples.",
    "Hold normal guidance for review when it contains instruction-override, approval-bypass, or exfiltration markers.",
    "Block critical actionable findings from MCP retrieval until source owners remove or explicitly recertify them.",
    "Regenerate the pack before secure context trust-pack generation so source hashes include the current scan result."
  ],
