  "intent": "Define the SecurityRecipes approval receipt control for agentic AI: every human approval that unlocks a privileged agent action must be scope-bound, time-boxed, role-checked, separated from the requesting identity, linked to risk acceptance when needed, and sealed into a run receipt before the action is trusted.",
  "positioning": {
    "buyer": "AI Platform, Security Engineering, IAM, GRC, product security, procurement security, and acquisition diligence teams",
    "category": "Scope-bound approval receipts for agentic AI control planes",
    "enterprise_promise": "SecurityRecipes can prove that high-impact agent actions are not merely accompanied by a human approval string; they are backed by replayable approval receipts with approver roles, scope hashes, expiry, separation of duties, risk acceptance, and run evidence.",
    "why_now": "Agentic AI systems now chain MCP tools, browser actions, remote agents, persistent memory, model-provider routes, and non-human identities. Enterprises need a receipt primitive that turns human approval into enforceable policy instead of a chat transcript or pull-request comment."
  },
  "residual_risks": [
    {
      "risk": "The open pack validates approval receipt shape, but production enforcement still needs source-host, ITSM, IAM, and MCP gateway integration.",
      "treatment": "Hosted deployments should verify approval source signatures, actor identities, tenant boundaries, and receipt hashes before forwarding privileged tool calls."
    },
    {
      "risk": "A valid approval can still be unsafe if the approved scope is broader than the actual business intent.",
      "treatment": "Bind approvals to stable scope hashes and regenerate them after changed paths, data classes, namespaces, release artifacts, or target resources drift."
    },
    {
      "risk": "Approval fatigue can normalize high-risk agent actions.",
      "treatment": "Use profile TTLs, two-key review, risk acceptance, and red-team replay to keep approval volume and bypass attempts visible."
    }
  ],
