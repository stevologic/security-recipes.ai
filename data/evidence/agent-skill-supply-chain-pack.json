{
  "decision_contract": {
    "decisions": [
      {
        "decision": "allow_pinned_readonly_skill",
        "meaning": "A registered, pinned, low-risk skill may run with read-only or context-only authority."
      },
      {
        "decision": "allow_guarded_skill",
        "meaning": "A registered skill may run only with declared sandbox, permission, egress, approval, and evidence controls."
      },
      {
        "decision": "hold_for_skill_security_review",
        "meaning": "The skill or requested permission set needs security-owner review before install, update, or run."
      },
      {
        "decision": "deny_untrusted_skill",
        "meaning": "The skill is registered but fails provenance, permission, version, isolation, or scan requirements."
      },
      {
        "decision": "deny_unregistered_skill",
        "meaning": "The skill is not in the SecurityRecipes supply-chain register and must not be installed or invoked."
      },
      {
        "decision": "kill_session_on_malicious_skill_signal",
        "meaning": "A kill signal, prohibited capability, or private-data-plus-egress pattern disables the agent session and creates incident evidence."
      }
    ],
    "default_decision": "deny_unregistered_skill",
    "kill_signals": [
      "skill attempts to read private keys, seed phrases, raw tokens, browser passwords, wallet material, or production credentials",
      "skill attempts to modify AGENTS.md, CLAUDE.md, SOUL.md, MEMORY.md, hook configs, or identity files outside an approved policy change",
      "skill combines private data access, untrusted content ingestion, and external network egress",
      "skill package hash changes without version bump, review, and pack regeneration",
      "skill invokes shell, package manager, curl, wget, PowerShell, or bash through untrusted retrieved context"
    ],
