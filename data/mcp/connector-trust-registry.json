{
  "schema_version": "1.0",
  "last_reviewed": "2026-05-02",
  "intent": "Inventory the MCP connector trust surface behind SecurityRecipes workflows so agent hosts, gateways, AI platform teams, and buyers can decide which tool namespaces are production-ready, which require approval, and which controls must be enforced before an agent may call them.",
  "positioning": {
    "buyer": "AI Platform, Product Security, IAM, GRC, and enterprise architecture teams",
    "category": "MCP connector trust registry",
    "enterprise_promise": "Every connector namespace used by an approved agentic remediation workflow is inventoried, risk-tiered, mapped to controls, and exposed as a generated trust pack.",
    "why_now": "MCP has made tool access easy. Enterprises now need the missing governance layer: connector inventory, scoped authorization, result inspection, evidence, and promotion criteria."
  },
  "trust_tiers": [
    {
      "id": "tier_0_public_context",
      "title": "Public Context",
      "description": "Read-only, public or open-source context with no enterprise data exposure.",
      "minimum_controls": [
        "pin_tool_descriptions",
        "audit_every_tool_call",
        "inspect_tool_results"
      ]
    },
    {
      "id": "tier_1_internal_read",
      "title": "Internal Read",
      "description": "Read-only enterprise context such as findings, SBOM inventory, CI status, ownership, or simulation output.",
      "minimum_controls": [
        "per_client_consent",
        "short_lived_workload_identity",
        "deny_token_passthrough",
        "pin_tool_descriptions",
        "inspect_tool_results",
        "deny_private_network_egress",
        "audit_every_tool_call",
        "session_binding"
      ]
    },
    {
      "id": "tier_2_scoped_write",
      "title": "Scoped Write",
      "description": "Bounded write access such as remediation branches, triage tickets, or evidence updates.",
      "minimum_controls": [
        "per_client_consent",
        "short_lived_workload_identity",
        "deny_token_passthrough",
        "pin_tool_descriptions",
        "inspect_tool_results",
        "deny_private_network_egress",
        "audit_every_tool_call",
        "session_binding",
        "write_scope_enforcement",
        "human_review_before_merge"
      ]
    },
    {
      "id": "tier_3_approval_required",
      "title": "Approval Required",
      "description": "High-impact staged operations that cannot execute until a typed human approval record is present.",
      "minimum_controls": [
        "per_client_consent",
        "short_lived_workload_identity",
        "deny_token_passthrough",
        "pin_tool_descriptions",
        "inspect_tool_results",
        "deny_private_network_egress",
        "audit_every_tool_call",
        "session_binding",
        "write_scope_enforcement",
        "typed_human_approval",
        "two_key_review",
        "kill_session_on_approval_bypass"
      ]
    },
    {
      "id": "tier_4_prohibited",
      "title": "Prohibited",
      "description": "Direct access to secrets, production signers, deployment credentials, registry publish keys, or live funds movement.",
      "minimum_controls": [
        "hard_deny",
        "audit_denied_attempts",
        "kill_session_on_attempt"
      ]
    }
  ],
  "standards_alignment": [
    {
      "id": "mcp-security-best-practices",
      "name": "Model Context Protocol Security Best Practices",
      "url": "https://modelcontextprotocol.io/specification/2025-06-18/basic/security_best_practices",
      "coverage": "Confused deputy prevention, token passthrough avoidance, SSRF controls, session safety, local server compromise, and scope minimization."
    },
    {
      "id": "mcp-authorization-2025-11-25",
      "name": "Model Context Protocol Authorization",
      "url": "https://modelcontextprotocol.io/specification/2025-11-25/basic/authorization",
      "coverage": "HTTP transport authorization, protected-resource metadata discovery, OAuth client ID metadata documents, resource-bound tokens, scope challenges, step-up authorization, consent, redirect validation, and restricted MCP server access."
    },
    {
      "id": "owasp-agentic-top-10-2026",
      "name": "OWASP Top 10 for Agentic Applications 2026",
      "url": "https://genai.owasp.org/2025/12/09/owasp-genai-security-project-releases-top-10-risks-and-mitigations-for-agentic-ai-security/",
      "coverage": "Tool misuse, identity abuse, agentic supply chain, unexpected code execution, memory or context poisoning, cascading failures, and rogue agents."
    },
    {
      "id": "owasp-mcp-tool-poisoning",
      "name": "OWASP MCP Tool Poisoning",
      "url": "https://owasp.org/www-community/attacks/MCP_Tool_Poisoning",
      "coverage": "Runtime tool-output poisoning and hidden instruction injection through MCP tool responses."
    },
    {
      "id": "nist-ai-rmf-1.0",
      "name": "NIST AI Risk Management Framework 1.0",
      "url": "https://www.nist.gov/itl/ai-risk-management-framework",
      "coverage": "Governed, mapped, measured, and managed AI system risk."
    },
    {
      "id": "nist-ai-600-1",
      "name": "NIST AI RMF Generative AI Profile",
      "url": "https://www.nist.gov/publications/artificial-intelligence-risk-management-framework-generative-artificial-intelligence",
      "coverage": "Generative AI deployment, data, lifecycle, third-party, and operational risk management."
    }
  ],
  "global_control_objectives": [
    "No user token passthrough to downstream systems.",
    "Exact namespace matching; no wildcard connector grants.",
    "Private, loopback, link-local, and cloud metadata network targets are denied unless the connector is explicitly local-development only.",
    "Tool descriptions, tool schemas, and elicitation schemas are pinned and diff-reviewed before promotion.",
    "Tool results are inspected as prompt-layer input before they are returned to the agent.",
    "Every tool call carries workflow_id, agent_id, run_id, identity_id, namespace, access mode, and policy pack hash.",
    "Write operations are staged, scoped, reversible where possible, and blocked from merge, release, publish, deploy, signing, or live funds movement."
  ],
