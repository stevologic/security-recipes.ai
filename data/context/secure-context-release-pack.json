        "meaning": "The requested release is active, hash-matched, policy-bound, and signed when the channel requires production-grade signing."
      },
      {
        "decision": "hold_for_signature",
        "meaning": "The release is structurally ready but production, trust-center, or diligence use requires a signature bundle and transparency proof."
      },
      {
        "decision": "hold_for_recertification",
        "meaning": "At least one source or workflow context package is stale, inactive, or missing current attestation evidence."
      },
      {
        "decision": "hold_for_poisoning_review",
        "meaning": "A source in the release has actionable poisoning findings or a blocked poisoning decision."
      },
      {
        "decision": "hold_for_eval_replay",
        "meaning": "Required secure-context eval scenarios are missing or no longer eval-ready."
      },
      {
        "decision": "deny_unregistered_release_source",
        "meaning": "The release references context that is not registered in the secure-context trust pack."
      },
      {
        "decision": "deny_release_hash_mismatch",
        "meaning": "Runtime-supplied source hashes do not match the generated release manifest."
      },
      {
        "decision": "deny_release_channel_mismatch",
        "meaning": "The caller requested a release through a channel the release was not built for."
      },
      {
        "decision": "kill_session_on_release_violation",
        "meaning": "The release request includes prohibited context, runtime kill signals, secrets, private keys, raw tokens, or unrestricted customer logs."
      }
