      "config": {
        "type": "prisma_cloud_alerts",
        "base_url": "https://api.prismacloud.io",
        "resource": "/alert",
        "filters": {
          "policy_severity": ["high", "critical"],
          "alert_status": ["open"]
        }
      }
    },
